{
  "name": "evolleyball",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx src/server/server.ts",
    "start": "tsx src/server/server.ts",
    "dev:all": "concurrently -k \"vite --host\" \"tsx src/server/server.ts\"",
    "play": "npm run build && tsx src/server/server.ts",
    "build": "tsc --noEmit && vite build",
    "smoke": "tsx scripts/smoke.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "three": "^0.165.0",
    "tsx": "^4.15.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/three": "^0.165.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "playwright-core": "^1.61.1",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
